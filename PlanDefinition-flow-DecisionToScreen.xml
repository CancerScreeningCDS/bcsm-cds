      <expression>
        <language value="text/cql"/>
        <expression value="SDMContinueScreeningLifeExpReason"/>
      </expression>
    </dynamicValue>
  </action>
  <action id="SDMDelayScreeningLactating">
    <condition>
      <kind value="applicability"/>
