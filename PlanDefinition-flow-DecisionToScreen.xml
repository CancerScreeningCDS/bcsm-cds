  <action id="SDMContinueScreeningAge">
    <condition>
      <kind value="applicability"/>
      <expression>
        <language value="text/cql"/>
        <expression value="ExistsSDMContinueScreeningAge"/>
      </expression>
    </condition>
    <definitionCanonical value="http://cancerscreeningcds.github.io/bcsm-cds/ActivityDefinition/CommunicateSDMContinueScreening|1.0.0"/>
    <dynamicValue>
      <path value="reasonCode[0].coding[0]"/>
      <expression>
        <language value="text/cql"/>
        <expression value="SDMContinueScreeningAgeReason"/>
      </expression>
    </dynamicValue>
  </action>
  <action id="SDMContinueScreeningLifeExp">
    <condition>
      <kind value="applicability"/>
      <expression>
        <language value="text/cql"/>
